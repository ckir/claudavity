# Copy this file to `.env` (which is gitignored) and fill in your key.
#
# The google-antigravity SDK authenticates with a Gemini API key. It does NOT
# reuse the `agy` CLI's OAuth login (~/.gemini/oauth_creds.json) — see the README
# "Authentication" section. Get a free key at https://aistudio.google.com/app/apikey
#
# Alternatives to GEMINI_API_KEY: Vertex AI / Application Default Credentials (ADC).

GEMINI_API_KEY=paste-your-key-here
